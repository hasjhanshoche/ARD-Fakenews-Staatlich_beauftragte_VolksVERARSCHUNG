

$(document).ready(function() {
    "use strict"; // Start of use strict

$('#cookie-settings').click(function(e){
	e.preventDefault();
	$('#cookie').removeClass("hidden");
	$('#cookie').show();
});

//-------------------------------------------------------------------------------------------------------------------
// jQuery for page scrolling feature - requires jQuery Easing plugin
//-------------------------------------------------------------------------------------------------------------------
    $('a.page-scroll, .nav-link').bind('click', function(event) {
        var $anchor = $(this);
		var $anchor =  '#'+$anchor.attr('href').split('#')[1]; // fix hash LS 12032019
        $('html, body').stop().animate({
            scrollTop: ($($anchor).offset().top - 0)
        }, 1250, 'easeInOutExpo');
        event.preventDefault();
    });
//-------------------------------------------------------------------------------------------------------------------
//BACK TO TOP
//-------------------------------------------------------------------------------------------------------------------
//Check to see if the window is top if not then display button
	if($(window).width() > 992){
	
	//BACK TOP TOP
		$(window).scroll(function(){
			if ($(this).scrollTop() > 300) {
				$('#backtotop').fadeIn();
			} else {
				$('#backtotop').fadeOut();
			}
		});
		//Click event to scroll to top
    $('#backtotop').click(function(){
        $('html, body').animate({scrollTop : 0},800);
        return false;
    });
	
	}
//-------------------------------------------------------------------------------------------------------------------
//DATA-IMAGE-SRC
//-------------------------------------------------------------------------------------------------------------------
	$( "#page-document header, #page-explore header, #page-report header" ).each(function() {
	  var attr = $(this).attr('data-background');
	
	  if (typeof attr !== typeof undefined && attr !== false) {
		  $(this).css('background-image', 'url('+attr+')');
		  
	  }
	
	});
//-------------------------------------------------------------------------------------------------------------------
//PARALLAX HEADER
//-------------------------------------------------------------------------------------------------------------------
	/**
 * Author: Heather Corey
 * jQuery Simple Parallax Plugin
 *
 */
(function($) {
    $.fn.parallax = function(options) {
        var windowHeight = $(window).height();

        // Establish default settings
        var settings = $.extend({
            speed        : 0.15
        }, options);

        // Iterate over each object in collection
        return this.each( function() {

        // Save a reference to the element
        var $this = $(this);

        // Set up Scroll Handler
        $(document).scroll(function(){

    var scrollTop = $(window).scrollTop();
            var offset = $this.offset().top;
            var height = $this.outerHeight();

    // Check if above or below viewport
if (offset + height <= scrollTop || offset >= scrollTop + windowHeight) {
return;
}

var yBgPosition = Math.round((offset - scrollTop) * settings.speed);


                // Apply the Y Background Position to Set the Parallax Effect
    $this.css('background-position', 'center ' + yBgPosition + 'px');
                
        });
        });
    };
}(jQuery));
	
$('#page-document header, #page-explore header, #page-report header').parallax({
speed : 0.15
});

